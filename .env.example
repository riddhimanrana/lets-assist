# ---- Core app ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Supabase (local CLI stack) ----
# Get these from: `npm run supabase:status`
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_LOCAL_ANON_KEY
SUPABASE_SECRET_KEY=YOUR_LOCAL_SERVICE_ROLE_KEY
# Keep this aligned with SUPABASE_SECRET_KEY for local cron/worker routes.
SUPABASE_SERVICE_ROLE_KEY=YOUR_LOCAL_SERVICE_ROLE_KEY

# Comma-separated list of platform super-admin emails.
# Defaults include riddhiman.rana@gmail.com if omitted.

# Optional remote snapshot passthrough for /api/admin/db-parity?remote=1
REMOTE_SUPABASE_URL=
REMOTE_SUPABASE_SERVICE_ROLE_KEY=

# ---- Internal/cron auth ----
CRON_SECRET=dev-only-cron-secret

# ---- Google OAuth (Supabase Auth + Calendar integration) ----
# Add localhost callback URLs in Google Cloud Console before using these.
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/google/callback

# ---- Optional worker toggles ----
AUTO_PUBLISH_ENABLED=false
ORG_CALENDAR_SYNC_WORKER_ENABLED=true
ORG_SHEET_SYNC_WORKER_ENABLED=false
PROJECT_CANCELLATION_WORKER_ENABLED=false
